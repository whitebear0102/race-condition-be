PORT=3000

# Docker Compose (service name mysql): dùng cho container server
DATABASE_URL=mysql://root:root_password@mysql:3306/race_condition_db
# Chạy Nest trực tiếp trên máy: dùng 127.0.0.1 và mở port 3306 từ container
# DATABASE_URL=mysql://root:root_password@127.0.0.1:3306/race_condition_db

REDIS_HOST=redis
REDIS_PORT=6379

KAFKA_BROKER=kafka:9092
